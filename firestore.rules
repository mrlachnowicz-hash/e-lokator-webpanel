rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function canUse() {
      return signedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        getMyData().get('appBlocked', false) == false
      );
    }

    function isOwner() {
      return signedIn() && (
        request.auth.token.get('owner', false) == true ||
        request.auth.token.email in ["mrlachnowicz@gmail.com"]
      );
    }

    function myRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getMyData().get('role', 'RESIDENT')
        : 'RESIDENT';
    }

    function myCommId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? getMyData().get('communityId', '')
        : '';
    }

    function isAdminOrMaster() {
      return canUse() && (myRole() == "ADMIN" || myRole() == "MASTER");
    }

    function isCommunityStaff() {
      return canUse() && (myRole() == "ADMIN" || myRole() == "MASTER" || myRole() == "ACCOUNTANT");
    }

    function isMember(communityId) {
      return canUse() && (myCommId() == communityId || isOwner());
    }

    function panelAccessEnabled(communityId) {
      return exists(/databases/$(database)/documents/communities/$(communityId)) &&
        get(/databases/$(database)/documents/communities/$(communityId)).data.get('panelAccessEnabled', false) == true;
    }

    function canUsePanel(communityId) {
      return isMember(communityId) && panelAccessEnabled(communityId) && (myRole() == "MASTER" || myRole() == "ACCOUNTANT" || isOwner());
    }

    function canManagePanel(communityId) {
      return (isOwner() || ((myRole() == "MASTER" || myRole() == "ACCOUNTANT") && myCommId() == communityId)) && panelAccessEnabled(communityId);
    }

    match /users/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        (myCommId() != "" && myCommId() == resource.data.get('communityId', '')) ||
        isAdminOrMaster()
      );
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (
        request.auth.uid == uid ||
        (isAdminOrMaster() && myCommId() == resource.data.get('communityId', '') &&
         request.resource.data.diff(resource.data).changedKeys().hasOnly([
           "chatMutedUntilMs", "chatBanned", "appBlocked", "blockedAtMs"
         ]))
      );
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create: if canUse() || isOwner();
      allow update, delete: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);

      match /seat_purchases/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /streets/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /streetAssignments/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /contractorAssignments/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /tickets/{ticketId} {
        allow read: if isMember(communityId);
        allow create: if isMember(communityId);
        allow update, delete: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /contractor_performance_logs/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /calendar/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /gates/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /phoneNumbers/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /announcements/{annId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /residentAnnouncements/{annId} {
        allow read: if isMember(communityId);
        allow create, update: if isMember(communityId);
        allow delete: if isAdminOrMaster() || (isMember(communityId) && resource.data.createdByUid == request.auth.uid);
      }

      match /votes/{voteId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
        match /ballots/{ballotId} {
          allow list, read: if isMember(communityId);
          allow write: if isMember(communityId) && getMyData().get('flatId', '') == ballotId;
        }
      }

      match /chatMessages/{msgId} {
        allow read: if isMember(communityId);
        allow create: if isMember(communityId) && getMyData().get('chatBanned', false) == false;
        allow update: if isMember(communityId) && resource.data.senderUid == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['deleted', 'deletedAtMs']);
      }

      match /correspondence/{resUid} {
        allow read, write: if (resUid == request.auth.uid && canUse()) || (isAdminOrMaster() && myCommId() == communityId);
        match /messages/{msgId} {
          allow read, create: if (resUid == request.auth.uid && canUse()) || (isAdminOrMaster() && myCommId() == communityId);
          allow delete: if isAdminOrMaster() && myCommId() == communityId;
        }
      }

      match /activeInvites/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /staircases/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /flats/{docId} {
        allow read: if isMember(communityId) || canUsePanel(communityId);
        allow write: if false;
      }

      match /payers/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if false;
      }

      match /invoices/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /charges/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /settlements/{docId} {
        allow read: if canUsePanel(communityId) || (isMember(communityId) && getMyData().get('flatId', '') == resource.data.get('flatId', ''));
        allow write: if canManagePanel(communityId);
      }

      match /settlementDrafts/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /payments/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /ksefInvoices/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /meters/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /meterReadings/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /ksef/{document=**} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /reviewQueue/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /aiSuggestions/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /invoiceRules/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId);
      }

      match /dues/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }

      match /members/{docId} {
        allow read: if isMember(communityId);
        allow write: if isOwner() || (isAdminOrMaster() && myCommId() == communityId);
      }
    }

    match /communityNames/{name} {
      allow read, write: if signedIn();
    }

    match /invites/{inviteId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /seat_requests/{reqId} {
      allow create: if canUse() && myRole() == "MASTER" && request.resource.data.communityId == myCommId() && request.resource.data.status == "PENDING";
      allow read, update, delete: if isOwner();
    }

    match /activation_codes/{code} {
      allow read, write: if isOwner();
    }

    match /join_codes/{code} {
      allow read, write: if isOwner();
    }

    match /webSessions/{token} {
      allow read, write: if false;
    }
  }
}
