rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function myData() {
      return userExists(request.auth.uid) ? userData(request.auth.uid) : {};
    }

    function profileCommunityId(data) {
      return data.get(
        'communityId',
        data.get(
          'customerId',
          data.get(
            'activeCommunityId',
            data.get(
              'currentCommunityId',
              data.get('selectedCommunityId', '')
            )
          )
        )
      );
    }

    function profileRole(data) {
      return data.get('role', 'RESIDENT');
    }

    function isOwner() {
      return signedIn() && (
        request.auth.token.get('owner', false) == true ||
        request.auth.token.email in ['mrlachnowicz@gmail.com']
      );
    }

    function canUse() {
      return signedIn() && (
        !userExists(request.auth.uid) ||
        (
          myData().get('appBlocked', false) == false &&
          myData().get('blocked', false) == false &&
          myData().get('isBlocked', false) == false
        )
      );
    }

    function myRole() {
      return signedIn() && userExists(request.auth.uid) ? profileRole(myData()) : 'RESIDENT';
    }

    function myCommunityId() {
      return signedIn() && userExists(request.auth.uid) ? profileCommunityId(myData()) : '';
    }

    function communityExists(communityId) {
      return exists(/databases/$(database)/documents/communities/$(communityId));
    }

    function communityData(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data;
    }

    function communityPanelEnabled(communityId) {
      return communityExists(communityId) && communityData(communityId).get(
        'panelAccessEnabled',
        communityData(communityId).get(
          'accessToPanel',
          communityData(communityId).get(
            'panelActive',
            communityData(communityId).get(
              'panelEnabled',
              communityData(communityId).get(
                'webpanelEnabled',
                communityData(communityId).get('webPanelEnabled', false)
              )
            )
          )
        )
      ) == true;
    }

    function isMember(communityId) {
      return canUse() && (myCommunityId() == communityId || isOwner());
    }

    function canManageCommunity(communityId) {
      return isOwner() || (isMember(communityId) && (myRole() == 'MASTER' || myRole() == 'ADMIN'));
    }

    function canManagePanel(communityId) {
      return isOwner() || (
        isMember(communityId) &&
        communityPanelEnabled(communityId) &&
        (myRole() == 'MASTER' || myRole() == 'ADMIN' || myRole() == 'ACCOUNTANT')
      );
    }

    function canUsePanel(communityId) {
      return isOwner() || (
        isMember(communityId) &&
        communityPanelEnabled(communityId) &&
        (myRole() == 'MASTER' || myRole() == 'ADMIN' || myRole() == 'ACCOUNTANT')
      );
    }

    function isOwnFlat(flatId) {
      return userExists(request.auth.uid) && myData().get('flatId', '') == flatId;
    }

    match /users/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        isOwner() ||
        (userExists(request.auth.uid) && profileCommunityId(resource.data) != '' && profileCommunityId(resource.data) == myCommunityId())
      );

      allow create: if signedIn() && request.auth.uid == uid;

      allow update: if signedIn() && (
        request.auth.uid == uid ||
        (
          isMember(profileCommunityId(resource.data)) &&
          (myRole() == 'MASTER' || myRole() == 'ADMIN' || myRole() == 'ACCOUNTANT') &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'chatMutedUntilMs',
            'chatBanned',
            'appBlocked',
            'blocked',
            'isBlocked',
            'status',
            'blockedAtMs',
            'updatedAtMs',
            'removedAtMs',
            'removedByUid'
          ])
        ) ||
        isOwner()
      );

      allow delete: if false;
    }

    match /communities/{communityId} {
      allow read: if signedIn() && (isMember(communityId) || isOwner());
      allow create: if canUse() || isOwner();
      allow update: if canManageCommunity(communityId) || isOwner();
      allow delete: if isOwner();

      match /seat_purchases/{docId} {
        allow read: if isMember(communityId) || isOwner();
        allow write: if isOwner();
      }

      match /streets/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /streetAssignments/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /staircases/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /contractorAssignments/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /tickets/{ticketId} {
        allow read: if isMember(communityId);
        allow create: if isMember(communityId);
        allow update, delete: if canManageCommunity(communityId) || isOwner();
      }

      match /contractor_performance_logs/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /calendar/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /gates/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /phoneNumbers/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /announcements/{annId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /residentAnnouncements/{annId} {
        allow read: if isMember(communityId);
        allow create, update: if isMember(communityId);
        allow delete: if canManageCommunity(communityId) || isOwner() || (isMember(communityId) && resource.data.createdByUid == request.auth.uid);
      }

      match /votes/{voteId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();

        match /ballots/{ballotId} {
          allow read: if isMember(communityId);
          allow write: if isMember(communityId) && isOwnFlat(ballotId);
        }
      }

      match /chatMessages/{msgId} {
        allow read: if isMember(communityId);
        allow create: if isMember(communityId) && myData().get('chatBanned', false) == false;
        allow update: if isMember(communityId) && (
          resource.data.senderUid == request.auth.uid ||
          canManageCommunity(communityId) ||
          isOwner()
        ) && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'deleted',
          'deletedAtMs',
          'deletedByUid',
          'moderationReason',
          'updatedAtMs'
        ]);
        allow delete: if false;
      }

      match /correspondence/{resUid} {
        allow read, write: if (resUid == request.auth.uid && canUse()) || canManageCommunity(communityId) || isOwner();

        match /messages/{msgId} {
          allow read, create: if (resUid == request.auth.uid && canUse()) || canManageCommunity(communityId) || isOwner();
          allow delete: if canManageCommunity(communityId) || isOwner();
        }
      }

      match /activeInvites/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /flats/{docId} {
        allow read: if isMember(communityId) || canUsePanel(communityId);
        allow write: if false;
      }

      match /payers/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if false;
      }

      match /balances/{docId} {
        allow read: if canUsePanel(communityId) || (isMember(communityId) && isOwnFlat(docId));
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /charges/{docId} {
        allow read: if canUsePanel(communityId) || (isMember(communityId) && isOwnFlat(resource.data.get('flatId', '')));
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /payments/{docId} {
        allow read: if canUsePanel(communityId) || (isMember(communityId) && isOwnFlat(resource.data.get('flatId', '')));
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /settlements/{docId} {
        allow read: if canUsePanel(communityId) || (isMember(communityId) && isOwnFlat(resource.data.get('flatId', '')));
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /settlementDrafts/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /invoices/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /reviewQueue/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /aiSuggestions/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /invoiceRules/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /ksefInvoices/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /meters/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /meterReadings/{docId} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /ksef/{document=**} {
        allow read: if canUsePanel(communityId);
        allow write: if canManagePanel(communityId) || isOwner();
      }

      match /dues/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /members/{docId} {
        allow read: if isMember(communityId);
        allow write: if canManageCommunity(communityId) || isOwner();
      }

      match /aiSources/{docId} {
        allow read: if canManageCommunity(communityId) || isOwner();
        allow write: if false;
      }

      match /aiNews/{docId} {
        allow read: if isMember(communityId);
        allow write: if false;
      }
    }

    match /communityNames/{name} {
      allow read, write: if signedIn();
    }

    match /invites/{inviteId} {
      allow read: if signedIn() && (
        isOwner() ||
        resource.data.invitedByUid == request.auth.uid ||
        profileCommunityId(resource.data) == myCommunityId()
      );
      allow write: if false;
    }

    match /seat_requests/{requestId} {
      allow create: if canUse() &&
        (myRole() == 'MASTER' || myRole() == 'ADMIN') &&
        request.resource.data.communityId == myCommunityId() &&
        request.resource.data.status == 'PENDING';
      allow read: if isOwner() || (signedIn() && resource.data.communityId == myCommunityId());
      allow update, delete: if isOwner();
    }

    match /activation_codes/{code} {
      allow read, write: if isOwner();
    }

    match /join_codes/{code} {
      allow read, write: if isOwner();
    }

    match /webSessions/{token} {
      allow read, write: if false;
    }
  }
}
